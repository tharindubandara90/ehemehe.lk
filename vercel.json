{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Strict-Transport-Security": "max-age=31536000",
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(self)",
        "X-DNS-Prefetch-Control": "on"
      },
      "continue": true
    },
    {
      "src": "/post-ad(?:\\.html)?",
      "headers": {
        "Location": "/post"
      },
      "status": 308
    },
    {
      "src": "/terms(?:/)?",
      "dest": "/terms.html"
    },
    {
      "src": "/privacy(?:/)?",
      "dest": "/privacy.html"
    },
    {
      "src": "/safety(?:/)?",
      "dest": "/safety.html"
    },
    {
      "src": "/contact(?:/)?",
      "dest": "/contact.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js?__api_route=$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=2592000, stale-while-revalidate=604800"
      },
      "continue": true
    },
    {
      "src": "/(.*)\\.html",
      "headers": {
        "Cache-Control": "no-cache, max-age=0, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "/(.*)\\.(?:js|css)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cleanup-expired-ads",
      "schedule": "15 3 * * *"
    }
  ]
}
