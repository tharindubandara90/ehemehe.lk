{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin.html"
    },
    {
      "source": "/browse",
      "destination": "/browse.html"
    },
    {
      "source": "/browse/",
      "destination": "/browse.html"
    },
    {
      "source": "/post-ad",
      "destination": "/post-ad.html"
    },
    {
      "source": "/ad/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/category/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/categories",
      "destination": "/index.html"
    },
    {
      "source": "/search",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/help",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}