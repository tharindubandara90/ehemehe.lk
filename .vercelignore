# Critical: old deployments used one Vercel Function per file under /api.
# When this project is copied over an existing Git working tree, Windows
# "Replace files" does not delete that old directory. Exclude every possible
# legacy API path so stale tracked files can never exceed the Hobby limit.
api/
api/**
/api/
/api/**
app/api/
app/api/**
pages/api/
pages/api/**
src/api/
src/api/**

public/ad/**
node_modules/**
.git/**
*.zip
README*.md
*_VALIDATION.json
*VALIDATION*.json
**/*_test.js
**/*_regression_test.js
**/*_regression-test.js
scripts/run-regression-tests.js
scripts/http-regression-test.js
supabase_*.sql
scrape.js

# Never upload stale frontend build outputs from earlier project versions.
dist/**
build/**
out/**
.next/**
.output/**
.vercel/output/**
public-old/**
public_backup/**
public-backup/**
