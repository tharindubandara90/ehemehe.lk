# Text.lk SMS Gateway
# Regenerate your token if it was shared in a screenshot.
TEXTLK_API_TOKEN=replace_with_textlk_api_token
TEXTLK_SENDER_ID=EHEMEHE
OTP_SECRET=replace_with_long_random_secret
OTP_EXPIRY_MINUTES=5
OTP_SMS_TEMPLATE=Your ehemehe.lk verification code is {{code}}. Do not share this code.

# Optional: only for OTP logs in Supabase
SUPABASE_URL=https://ieymsjeywkapqeniirlm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key_only_on_server

# Optional server override. If omitted, the public key is read from public/supabase.js.
SUPABASE_ANON_KEY=replace_with_public_anon_key

# Optional: Vercel Cron automatically sends this value as a Bearer token.
# Set a long random secret to protect the 25-day ad cleanup endpoint.
CRON_SECRET=replace_with_long_random_cron_secret
